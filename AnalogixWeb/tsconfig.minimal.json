{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": { "@/*": ["./src/*"] },
    "strictNullChecks": true
  },
  "include": [
    "src/lib/**/*.ts",
    "src/hooks/**/*.ts",
    "src/utils/**/*.ts",
    "src/types/**/*.ts",
    "src/constants/**/*.ts",
    "src/context/**/*.ts",
    "src/services/**/*.ts",
    "src/data/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "src/tests"
  ]
}
