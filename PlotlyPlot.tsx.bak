"use client";

import React, { useEffect, useRef, useState } from "react";
import { RefreshCw } from "lucide-react";

interface PlotlyPlotProps {
  code: string;
}

// Parse the Plotly-like code block and extract data/traces/layout
const parsePlotlyCode = (code: string) => {
  const lines = code.trim().split("\n").map(l => l.trim()).filter(Boolean);
  
  const traces: Array<{
    type: string;
    x?: number[];
    y?: number[];
    z?: number[];
    mode?: string;
    name?: string;
    marker?: { color?: string; size?: number };
    line?: { color?: string; width: number };
  }> = [];
  
  const layout: Record<string, any> = {
    autosize: true,
    margin: { t: 40, b: 40, l: 50, r: 20 },
  };
  
  let currentTrace: any = null;
  let currentArray: "x" | "y" | "z" | null = null;
  
  for (const line of lines) {
    // Title
    const titleMatch = line.match(/^title:\s*(.+)$/i);
    if (titleMatch) {
      layout.title = titleMatch[1].trim();
      continue;
    }
    
    // X-axis label
    const xLabelMatch = line.match(/^xlabel:\s*(.+)$/i);
    if (xLabelMatch) {
      layout.xaxis = { ...layout.xaxis, title: xLabelMatch[1].trim() };
      continue;
    }
    
    // Y-axis label
    const yLabelMatch = line.match(/^ylabel:\s*(.+)$/i);
    if (yLabelMatch) {
      layout.yaxis = { ...layout.yaxis, title: yLabelMatch[1].trim() };
      continue;
    }
    
    // Trace type (scatter, bar, etc.)
    const typeMatch = line.match(/^type:\s*(\w+)$/i);
    if (typeMatch) {
      if (currentTrace) traces.push(currentTrace);
      currentTrace = { type: typeMatch[1].toLowerCase(), mode: "lines+markers" };
      currentArray = null;
      continue;
    }
    
    // Trace name/label
    const nameMatch = line.match(/^name:\s*(.+)$/i);
    if (nameMatch && currentTrace) {
      currentTrace.name = nameMatch[1].trim();
      continue;
    }
    
    // X data
    const xMatch = line.match(/^x:\s*\[([\d\s.,-]+)\]/i);
    if (xMatch && currentTrace) {
      currentTrace.x = xMatch[1].split(/[\s,]+/).filter(Boolean).map(Number);
      continue;
    }
    
    // X data (multi-line)
    if (line === "x:" || line === "x: [") {
      currentArray = "x";
      if (currentTrace) currentTrace.x = [];
      continue;
    }
    
    // Y data
    const yMatch = line.match(/^y:\s*\[([\d\s.,-]+)\]/i);
    if (yMatch && currentTrace) {
      currentTrace.y = yMatch[1].split(/[\s,]+/).filter(Boolean).map(Number);
      continue;
    }
    
    // Y data (multi-line)
    if (line === "y:" || line === "y: [") {
      currentArray = "y";
      if (currentTrace) currentTrace.y = [];
      continue;
    }
    
    // Array values (for multi-line x/y/z)
    const valuesMatch = line.match(/^[\d.\-eE+\s,]+$/);
    if (valuesMatch && currentArray && currentTrace) {
      const values = valuesMatch[0].split(/[\s,]+/).filter(Boolean).map(Number);
      if (currentArray === "x") currentTrace.x = [...(currentTrace.x || []), ...values];
      if (currentArray === "y") currentTrace.y = [...(currentTrace.y || []), ...values];
      continue;
    }
    
    // Marker color
    const markerColorMatch = line.match(/^marker\.color:\s*(#[0-9a-fA-F]+|\w+)$/i);
    if (markerColorMatch && currentTrace) {
      currentTrace.marker = { ...currentTrace.marker, color: markerColorMatch[1] };
      continue;
    }
    
    // Line color
    const lineColorMatch = line.match(/^line\.color:\s*(#[0-9a-fA-F]+|\w+)$/i);
    if (lineColorMatch && currentTrace) {
      currentTrace.line = { ...currentTrace.line, color: lineColorMatch[1], width: 2 };
      continue;
    }
    
    // Mode (lines, markers, lines+markers)
    const modeMatch = line.match(/^mode:\s*(\w+(?:\+\w+)*)$/i);
    if (modeMatch && currentTrace) {
      currentTrace.mode = modeMatch[1];
      continue;
    }
  }
  
  // Push the last trace
  if (currentTrace) traces.push(currentTrace);
  
  return { traces, layout };
};

const PlotlyPlot: React.FC<PlotlyPlotProps> = ({ code }) => {
  const containerRef = useRef<HTMLDivElement>(null);
  const [plotlyLoaded, setPlotlyLoaded] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const [renderKey, setRenderKey] = useState(0);

  // Load Plotly.js dynamically
  useEffect(() => {
    if (typeof window === "undefined" || (window as any).Plotly) {
      setPlotlyLoaded(true);
      return;
    }

    const script = document.createElement("script");
    script.src = "https://cdn.plot.ly/plotly-2.27.0.min.js";
    script.async = true;
    script.onload = () => setPlotlyLoaded(true);
    script.onerror = () => setError("Failed to load Plotly");
    document.body.appendChild(script);

    return () => {
      document.body.removeChild(script);
    };
  }, []);

  // Render the plot
  useEffect(() => {
    if (!plotlyLoaded || !containerRef.current) return;

    const render = async () => {
      try {
        const { traces, layout } = parsePlotlyCode(code);
        const config = {
          responsive: true,
          displayModeBar: true,
          modeBarButtonsToRemove: ["lasso2d", "select2d"],
          displaylogo: false,
        };

        await (window as any).Plotly.newPlot(
          containerRef.current,
          traces,
          {
            ...layout,
            paper_bgcolor: "transparent",
            plot_bgcolor: "transparent",
            font: { color: "hsl(var(--foreground))" },
            xaxis: {
              ...layout.xaxis,
              gridcolor: "hsl(var(--border))",
              linecolor: "hsl(var(--border))",
            },
            yaxis: {
              ...layout.yaxis,
              gridcolor: "hsl(var(--border))",
              linecolor: "hsl(var(--border))",
            },
          },
          config
        );
        setError(null);
      } catch (e) {
        console.error("[PlotlyPlot] Render error:", e);
        setError("Failed to render plot");
      }
    };

    render();

    // Cleanup on unmount
    return () => {
      if (containerRef.current && (window as any).Plotly) {
        (window as any).Plotly.purge(containerRef.current);
      }
    };
  }, [plotlyLoaded, code, renderKey]);

  if (error) {
    return (
      <div className="my-4 rounded-2xl overflow-hidden border border-border/30 bg-muted/20 p-6 flex items-center justify-center gap-2">
        <p className="text-xs text-destructive">{error}</p>
      </div>
    );
  }

  if (!plotlyLoaded) {
    return (
      <div className="my-4 rounded-2xl overflow-hidden border border-border/30 bg-muted/20 p-6 flex items-center justify-center gap-2">
        <div className="w-1.5 h-1.5 rounded-full bg-primary/40 animate-pulse" />
        <p className="text-xs text-muted-foreground/50 italic">Loading Plotly…</p>
      </div>
    );
  }

  return (
    <div className="my-4 rounded-2xl overflow-hidden border border-border/30 bg-muted/20 relative">
      <div className="absolute top-2 right-2 z-10 flex gap-1">
        <button
          onClick={() => setRenderKey(k => k + 1)}
          className="p-1.5 rounded-lg bg-background/80 hover:bg-background text-muted-foreground hover:text-foreground transition-colors"
          title="Re-render plot"
        >
          <RefreshCw className="w-3.5 h-3.5" />
        </button>
      </div>
      <div ref={containerRef} className="w-full h-80" />
    </div>
  );
};

export default PlotlyPlot;
