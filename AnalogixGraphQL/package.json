{
  "name": "@analogix/graphql",
  "version": "0.1.0",
  "private": true,
  "description": "Analogix GraphQL BFF — Apollo Server v5 connecting web + mobile to Supabase and Groq",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
