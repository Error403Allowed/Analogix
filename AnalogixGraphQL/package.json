    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/graphql-depth-limit": "^1.1.6",
    "@types/node": "^22.19.11",
    "@types/ws": "^8.5.13",
    "tsx": "^4.20.6",
    "typescript": "5.9.3"
