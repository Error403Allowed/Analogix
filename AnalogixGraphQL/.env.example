# =============================================================================
# AnalogixGraphQL — Server runtime configuration
# Copy this file to `.env` and fill in the placeholders.
# NEVER commit your real `.env` file. It's already in the root .gitignore.
# =============================================================================

# Server
PORT=4000
NODE_ENV=development
# Comma-separated origins allowed to call the GraphQL endpoint.
# Use the mobile app's scheme + your web origin in dev.
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:19006

# -----------------------------------------------------------------------------
# Supabase  (https://supabase.com/dashboard/project/_/settings/api)
# Required for auth verification and RLS-aware data access.
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# -----------------------------------------------------------------------------
# Groq  (https://console.groq.com/keys)
# Two keys are supported for soft rate-limit failover (matches AnalogixWeb).
# -----------------------------------------------------------------------------
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_KEY
GROQ_API_KEY_2=gsk_REPLACE_WITH_OPTIONAL_SECONDARY_KEY

# -----------------------------------------------------------------------------
# Google OAuth  (https://console.cloud.google.com/apis/credentials)
# Used for verifying ID tokens. Optional for v1 — only required if you proxy
# Google sign-in through the BFF instead of expo-auth-session on device.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=YOUR-WEB-CLIENT-ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-REPLACE-WITH-SECRET

# -----------------------------------------------------------------------------
# Desmos  (https://www.desmos.com/api/v1.5/docs)
# -----------------------------------------------------------------------------
DESMOS_API_KEY=REPLACE-WITH-YOUR-DESMOS-KEY

# -----------------------------------------------------------------------------
# Redis  (https://upstash.com — free tier works)
# Used by graphql-redis-subscriptions for pub/sub across chatStream + room events.
# Leave REDIS_URL empty to fall back to in-process EventEmitter (dev only).
# -----------------------------------------------------------------------------
REDIS_URL=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
