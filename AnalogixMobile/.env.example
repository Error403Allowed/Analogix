# =============================================================================
# AnalogixMobile — runtime configuration
# Copy to `.env` (used by Expo's babel-preset-expo + eas build). Every var
# must be prefixed with `EXPO_PUBLIC_` to be inlined into the client bundle.
# NEVER commit your real `.env`.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase
# Create a project at https://supabase.com, then copy from
# Settings → API. These two are public-safe (used in the mobile app).
# -----------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# -----------------------------------------------------------------------------
# GraphQL BFF endpoints
# - For Android emulator, host is 10.0.2.2 (not localhost)
# - For iOS simulator, host is localhost
# - For physical devices, use your LAN IP or a tunneled URL
# -----------------------------------------------------------------------------
EXPO_PUBLIC_GRAPHQL_HTTP_URL=http://localhost:4000/graphql
EXPO_PUBLIC_GRAPHQL_WS_URL=ws://localhost:4000/graphql

# -----------------------------------------------------------------------------
# Google OAuth (for expo-auth-session)
# Match the iOS / Android client IDs configured in your Supabase project.
# See README → "Setting up Google sign-in" for the full flow.
# -----------------------------------------------------------------------------
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR-IOS-CLIENT-ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR-ANDROID-CLIENT-ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR-WEB-CLIENT-ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_REDIRECT_SCHEME=analogix

# -----------------------------------------------------------------------------
# EAS (Expo Application Services) — for `eas build` / `eas submit`
# Get a token at https://expo.dev/settings/access-tokens
# -----------------------------------------------------------------------------
EXPO_TOKEN=
