{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "22.16.0"
    },
    "preview": {
      "distribution": "internal",
      "node": "22.16.0"
    },
    "production": {
      "autoIncrement": true,
      "node": "22.16.0"
    },
    "production-apk": {
      "autoIncrement": true,
      "node": "22.16.0",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
